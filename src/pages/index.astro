---
import '../styles/global.css';
import { encode, PaymentOptions, CurrencyCode } from 'bysquare/pay';
import QRCode from 'qrcode';

// ── Obsah stránky (jednoducho upraviteľné na jednom mieste) ──────────────
const farma = {
  nazov: 'Na Lúke',
  zalozene: '2009',
  obec: 'Slovensko',
};

// Ceny a hmotnosti podľa telefonického zadania od farmy (jún 2026).
const produkty = [
  {
    id: 'lesny-med',
    nazov: 'Miešaný lesný med',
    tag: 'Med',
    popis:
      'Tmavý, hustý a plný chuti lesa. Stáčame ho do pohárov aj do väčších nádob — koľko potrebujete do špajze.',
    ceny: [
      { suma: '11 €', za: 'pohár 950 g (7 dcl)' },
      { suma: '50 €', za: '5 kg (3,5 l)' },
    ],
    ilustracia: 'med-tmavy',
  },
  {
    id: 'vceli-pel',
    nazov: 'Včelí peľ',
    tag: 'Z úľa',
    popis:
      'Čerstvý kvetový peľ priamo z úľa. Lyžička denne — malé zrnká plné energie z lúk.',
    ceny: [{ suma: '4 €', za: '100 g' }],
    ilustracia: 'pel',
  },
  {
    id: 'vajicka',
    nazov: 'Domáce vajíčka',
    tag: 'Z dvora',
    popis:
      'Od sliepok z voľného výbehu. Sýto oranžové žĺtka a škrupina, ktorá pozná len trávu, slnko a čerstvý vzduch.',
    ceny: [{ suma: '3,50 €', za: '10 ks' }],
    ilustracia: 'vajicka',
  },
  // Mäso (hydina) je zatiaľ vypnuté — Oto ho na webe (zatiaľ) nechce.
  // Na opätovné zapnutie stačí odkomentovať tieto dva produkty (ilustrácie
  // 'sliepka'/'kohut' aj ich štýly v <style> ostávajú pripravené v kóde).
  // {
  //   id: 'sliepka',
  //   nazov: 'Sliepka',
  //   tag: 'Hydina',
  //   popis:
  //     'Vyčistená a vypitvaná, pripravená rovno do hrnca. Sliepka, ktorá behala po tráve, nie po klietke.',
  //   ceny: [{ suma: '5 €', za: 'kus (cca 800 g)' }],
  //   ilustracia: 'sliepka',
  // },
  // {
  //   id: 'kohut',
  //   nazov: 'Kohút',
  //   tag: 'Hydina',
  //   popis:
  //     'Väčší a výdatný — na poctivú nedeľnú polievku či pečienku pre celú rodinu.',
  //   ceny: [{ suma: '16 €', za: 'kus (cca 2 kg)' }],
  //   ilustracia: 'kohut',
  // },
];

const kontakt = {
  email: 'lucnydedko@gmail.com',
  adresa: ['Nižná Slaná', 'Slovensko'],
  hodiny: [
    ['Sobota', '9:00 – 12:00'],
    ['Po – Pia', 'Po dohode vopred'],
    ['Nedeľa', 'Zatvorené'],
  ],
};

// ── Objednávka a doručenie (med a peľ poštou, cez Packetu) ──────────────
// Posielame iba med a včelí peľ; vajíčka sú len na osobný odber.
const objednavka = {
  kroky: [
    { nazov: 'Napíšte', text: 'Pošlite nám e-mail s tým, čo a koľko by ste chceli — med alebo včelí peľ.' },
    { nazov: 'Potvrdíme', text: 'Ozveme sa s dostupnosťou, cenou a poštovným podľa Packety.' },
    { nazov: 'Zaplatíte', text: 'Bankovým prevodom, na dobierku, alebo ako sa dohodneme.' },
    { nazov: 'Pošleme', text: 'Zabalíme a odošleme cez Packetu — poháre tak, aby cestu zvládli v poriadku.' },
  ],
  zony: [
    { kod: 'SK', nazov: 'Slovensko', text: 'Na Packeta výdajné miesto alebo na adresu, zvyčajne do 2–3 pracovných dní.', cena: 'poštovné podľa Packety' },
    { kod: 'CZ', nazov: 'Česko', text: 'Posielame aj k susedom — slovenský med si cestu do Česka rád nájde.', cena: 'poštovné podľa Packety' },
    { kod: 'Z dvora', nazov: 'Osobný odber', text: 'Med, peľ aj čerstvé vajíčka si vyzdvihnete priamo na farme v Nižnej Slanej.', cena: 'bez poštovného' },
  ],
  platby: [
    'Bankový prevod',
    'Dobierka — platba pri prevzatí',
    'Prípadne sa dohodneme v e-maile',
  ],
  // DOPLNIŤ skutočný IBAN (a meno majiteľa účtu). Kým je IBAN prázdny, na
  // stránke sa namiesto čísla zobrazí „platobné údaje pošleme v e-maile“
  // (nezverejňujeme falošný IBAN). Po vyplnení sa pri builde automaticky
  // vygeneruje aj QR kód na platbu (PAY by square).
  iban: '',
  majitelUctu: '',
};

// QR platba (PAY by square) — generuje sa pri builde, iba keď je vyplnený
// IBAN. Suma sa v QR neuvádza; zákazník ju doplní podľa potvrdzujúceho
// e-mailu (cena + poštovné sa líšia podľa objednávky).
const qrPlatbaSvg = objednavka.iban
  ? await QRCode.toString(
      encode({
        payments: [
          {
            type: PaymentOptions.PaymentOrder,
            currencyCode: CurrencyCode.EUR,
            bankAccounts: [{ iban: objednavka.iban.replace(/\s+/g, '') }],
            ...(objednavka.majitelUctu
              ? { beneficiary: { name: objednavka.majitelUctu } }
              : {}),
            paymentNote: 'Objednavka Na Luke',
          },
        ],
      }),
      { type: 'svg', errorCorrectionLevel: 'M', margin: 0 },
    )
  : '';

// Ručne kreslené SVG ilustrácie pre produktové karty (žiadne externé obrázky).
function renderIlustracia(typ: string): string {
  const jar = (telo: string, lid: string) => `
    <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
      <rect x="40" y="14" width="40" height="10" rx="3" fill="${lid}"/>
      <rect x="44" y="22" width="32" height="7" rx="2" fill="#fff" opacity="0.55"/>
      <path d="M34 34 q26 -6 52 0 v54 a8 8 0 0 1 -8 8 H42 a8 8 0 0 1 -8 -8 z" fill="${telo}"/>
      <rect x="46" y="56" width="28" height="22" rx="4" fill="#FBF3E2" opacity="0.92"/>
      <path d="M50 62 h20 M50 68 h20 M50 74 h14" stroke="${lid}" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
      <ellipse cx="46" cy="44" rx="5" ry="14" fill="#fff" opacity="0.22"/>
    </svg>`;
  switch (typ) {
    case 'med':
      return jar('#E0A93C', '#7A3B0E');
    case 'med-tmavy':
      return jar('#9A6722', '#3D2410');
    case 'vajicka':
      return `
        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="60" cy="92" rx="44" ry="9" fill="#7A3B0E" opacity="0.12"/>
          <g>
            <ellipse cx="42" cy="62" rx="20" ry="26" fill="#fdfaf0"/>
            <ellipse cx="36" cy="54" rx="6" ry="9" fill="#fff" opacity="0.7"/>
          </g>
          <g>
            <ellipse cx="74" cy="66" rx="21" ry="27" fill="#F3E3C0"/>
            <ellipse cx="68" cy="56" rx="6" ry="9" fill="#fff" opacity="0.6"/>
          </g>
          <ellipse cx="59" cy="48" rx="14" ry="18" fill="#fffdf6"/>
          <circle cx="59" cy="48" r="7" fill="#E0A93C"/>
        </svg>`;
    case 'sviecka':
      return `
        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="60" cy="100" rx="30" ry="7" fill="#7A3B0E" opacity="0.12"/>
          <rect x="44" y="38" width="32" height="58" rx="6" fill="#E4C98F"/>
          <rect x="49" y="38" width="6" height="58" fill="#fff" opacity="0.3"/>
          <ellipse cx="60" cy="38" rx="16" ry="5" fill="#D8B871"/>
          <rect x="58" y="22" width="4" height="12" rx="2" fill="#5A3A14"/>
          <path d="M60 6 q9 9 0 18 q-9 -9 0 -18z" fill="#E9A23B"/>
          <path d="M60 11 q5 6 0 12 q-5 -6 0 -12z" fill="#F6D77A"/>
        </svg>`;
    case 'pel':
      return `
        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="60" cy="104" rx="30" ry="6" fill="#7A3B0E" opacity="0.12"/>
          <rect x="40" y="16" width="40" height="9" rx="3" fill="#7A3B0E"/>
          <rect x="44" y="23" width="32" height="6" rx="2" fill="#fff" opacity="0.5"/>
          <path d="M36 38 q24 -6 48 0 v50 a8 8 0 0 1 -8 8 H44 a8 8 0 0 1 -8 -8 z" fill="#E9C46A" opacity="0.45"/>
          <g>
            <circle cx="48" cy="72" r="4" fill="#E0901E"/>
            <circle cx="57" cy="68" r="4.2" fill="#E8B24A"/>
            <circle cx="66" cy="72" r="4" fill="#C77A12"/>
            <circle cx="74" cy="70" r="3.5" fill="#E0901E"/>
            <circle cx="44" cy="81" r="3.6" fill="#E8B24A"/>
            <circle cx="53" cy="83" r="4" fill="#C77A12"/>
            <circle cx="62" cy="81" r="4" fill="#E0901E"/>
            <circle cx="71" cy="82" r="3.8" fill="#E8B24A"/>
            <circle cx="48" cy="91" r="3.5" fill="#C77A12"/>
            <circle cx="57" cy="92" r="3.8" fill="#E0901E"/>
            <circle cx="66" cy="91" r="3.6" fill="#E8B24A"/>
          </g>
          <ellipse cx="46" cy="48" rx="5" ry="13" fill="#fff" opacity="0.25"/>
        </svg>`;
    case 'sliepka':
      return `
        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="58" cy="108" rx="36" ry="6" fill="#7A3B0E" opacity="0.12"/>
          <path d="M24 56 q-14 4 -16 18 q14 -1 24 -10 z" fill="#E0A93C"/>
          <ellipse cx="54" cy="70" rx="36" ry="26" fill="#fdfaf2"/>
          <path d="M40 62 q16 -8 32 0 q-14 12 -34 7 z" fill="#F1E2BC"/>
          <circle cx="84" cy="46" r="15" fill="#fdfaf2"/>
          <path d="M84 31 q5 -9 11 -3 q-1 7 -9 8 z" fill="#C0392B"/>
          <path d="M82 60 q1 6 7 6 q2 -5 -2 -9 z" fill="#C0392B"/>
          <path d="M98 46 l13 4 -12 5 z" fill="#E58E26"/>
          <circle cx="90" cy="44" r="2.6" fill="#2A1E12"/>
          <path d="M48 95 l-3 13 M60 95 l3 13" stroke="#E58E26" stroke-width="3.5" fill="none" stroke-linecap="round"/>
        </svg>`;
    case 'kohut':
      return `
        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="58" cy="108" rx="36" ry="6" fill="#7A3B0E" opacity="0.12"/>
          <path d="M20 72 q-12 -34 14 -50 q4 6 -2 16 q14 -14 24 -10 q-6 8 -14 14 q10 -4 16 2 q-18 16 -38 34 z" fill="#3D4A2A"/>
          <path d="M22 70 q-6 -26 16 -40 q2 8 -4 16 q10 -8 16 -4 q-12 14 -28 32 z" fill="#4E5B3A"/>
          <ellipse cx="56" cy="72" rx="32" ry="25" fill="#B5701F"/>
          <ellipse cx="56" cy="78" rx="30" ry="18" fill="#9A5A14"/>
          <path d="M44 66 q16 -8 30 2 q-14 12 -32 7 z" fill="#D88A2B"/>
          <circle cx="84" cy="44" r="14" fill="#C77A1A"/>
          <path d="M74 52 q8 -4 18 0 q-6 10 -18 6 z" fill="#9A5A14"/>
          <path d="M80 30 q4 -10 9 -5 q3 -8 8 -2 q4 -6 7 2 q3 8 -6 12 q-10 4 -18 -1 z" fill="#C0392B"/>
          <path d="M82 58 q1 9 8 9 q2 -7 -2 -12 z" fill="#C0392B"/>
          <path d="M98 44 l14 4 -13 6 z" fill="#E58E26"/>
          <circle cx="90" cy="42" r="2.8" fill="#2A1E12"/>
          <path d="M50 96 l-3 13 M62 96 l3 13" stroke="#E58E26" stroke-width="3.8" fill="none" stroke-linecap="round"/>
        </svg>`;
    default:
      return '';
  }
}
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{farma.nazov} — bio med a domáce vajíčka rovno z dvora</title>
    <meta
      name="description"
      content="Malá rodinná farma Na Lúke. Miešaný lesný med, včelí peľ a domáce vajíčka z voľného výbehu. Poctivé domáce dobroty rovno z nášho dvora — od roku 2009."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- ── Navigácia ────────────────────────────────────────────────── -->
    <header class="nav" id="top">
      <div class="container nav__inner">
        <a class="nav__brand" href="#top" aria-label="Domov">
          <svg class="nav__mark" viewBox="0 0 32 32" aria-hidden="true">
            <circle cx="16" cy="16" r="15" fill="var(--honey)" />
            <path d="M16 8l5.2 3v6l-5.2 3-5.2-3v-6z" fill="none" stroke="var(--beeswax)" stroke-width="1.6" stroke-linejoin="round" />
            <circle cx="16" cy="15.4" r="1.7" fill="var(--beeswax)" />
          </svg>
          <span>Na <em>Lúke</em></span>
        </a>
        <button
          class="nav__toggle"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="nav-menu"
        >
          <span></span><span></span><span></span>
        </button>
        <nav class="nav__links" id="nav-menu" aria-label="Hlavné menu">
          <a href="#produkty">Produkty</a>
          <a href="#o-nas">O farme</a>
          <a href="#objednat">Objednať</a>
          <a href="#kontakt" class="nav__cta">Kontakt</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- ── Hero ──────────────────────────────────────────────────── -->
      <section class="hero">
        <div class="hero__honeycomb" aria-hidden="true"></div>
        <div class="container hero__inner">
          <div class="hero__text reveal">
            <p class="eyebrow">Bio · Od rodiny pre rodinu · Od {farma.zalozene}</p>
            <h1 class="hero__title">
              Med a vajíčka<br />rovno z&nbsp;nášho <span class="hero__accent">dvora.</span>
            </h1>
            <p class="hero__lead">
              Malá rodinná farma, kde včely opeľujú lúky a sliepky behajú po
              tráve. Žiadne skratky — len poctivé domáce dobroty, ktoré poznajú
              svoj úľ a svoju sliepku.
            </p>
            <div class="hero__actions">
              <a href="#produkty" class="btn">Naše produkty</a>
              <a href="#kontakt" class="btn btn--ghost">Kde nás nájdete</a>
            </div>
          </div>

          <!-- Signature: honey dipper with a slow drip -->
          <div class="hero__art reveal" aria-hidden="true">
            <svg class="dipper" viewBox="0 0 220 320" role="img">
              <title>Naberačka na med s kvapkou</title>
              <!-- handle -->
              <rect x="103" y="6" width="14" height="150" rx="7" fill="#8a5a2b" />
              <rect x="103" y="6" width="6" height="150" rx="3" fill="#a9743b" />
              <!-- dipper grooves -->
              <g fill="#caa15f">
                <ellipse cx="110" cy="168" rx="40" ry="13" />
                <ellipse cx="110" cy="190" rx="40" ry="13" />
                <ellipse cx="110" cy="212" rx="38" ry="12" />
                <ellipse cx="110" cy="233" rx="34" ry="11" />
                <ellipse cx="110" cy="252" rx="28" ry="10" />
              </g>
              <path d="M70 168 q40 130 40 130 q0 0 40 -130 z" fill="#d8a85a" opacity="0.0" />
              <!-- honey coating -->
              <path
                d="M70 165 q0 60 40 100 q40 -40 40 -100 q-40 22 -80 0 z"
                fill="url(#honeyGrad)"
              />
              <!-- the drip -->
              <g class="drip">
                <path d="M110 262 q-7 14 0 26 q7 -12 0 -26 z" fill="url(#honeyGrad)" />
                <circle class="drip__bead" cx="110" cy="292" r="7" fill="#D98A2B" />
              </g>
              <defs>
                <linearGradient id="honeyGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#E9C46A" />
                  <stop offset="1" stop-color="#C57E1E" />
                </linearGradient>
              </defs>
            </svg>
            <div class="seal hero__seal">
              <span>BIO<small>Na Lúke</small></span>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Produkty ──────────────────────────────────────────────── -->
      <section class="section" id="produkty">
        <div class="container">
          <header class="section__head reveal">
            <p class="eyebrow">Čo ponúkame</p>
            <h2 class="section__title">Zo dvora na váš stôl</h2>
            <p class="section__sub">
              Vyrábame v malom, podľa toho, čo dá sezóna. Keď niečo nie je na
              sklade, znamená to, že práve dozrieva.
            </p>
          </header>

          <div class="products">
            {produkty.map((p) => (
              <article class="card reveal">
                <div class={`card__art card__art--${p.ilustracia}`}>
                  <Fragment set:html={renderIlustracia(p.ilustracia)} />
                </div>
                <div class="card__body">
                  <span class="card__tag">{p.tag}</span>
                  <h3 class="card__title">{p.nazov}</h3>
                  <p class="card__text">{p.popis}</p>
                  <div class="card__prices">
                    {p.ceny.map((c) => (
                      <p class="card__price">
                        <span class="card__price-sum">{c.suma}</span>
                        <span class="card__price-za">{c.za}</span>
                      </p>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ── O farme ──────────────────────────────────────────────── -->
      <section class="story" id="o-nas">
        <div class="story__texture" aria-hidden="true"></div>
        <div class="container story__inner">
          <div class="story__text reveal">
            <p class="eyebrow eyebrow--light">O našej farme</p>
            <h2 class="story__title">
              Začalo to pár úľmi za domom a kŕdľom sliepok.
            </h2>
            <p>
              Dnes je to stále malá rodinná farma — taká, kde každý pohár medu
              pozná svoj úľ a každé vajíčko svoju sliepku. Zvieratá u nás žijú
              vonku, na slnku a tráve.
            </p>
            <p>
              Veríme, že na tom, čo jeme, naozaj záleží. A že tie najlepšie veci
              vznikajú pomaly, rukami a s trpezlivosťou. Preto nič neuponáhľame
              — necháme včely robiť svoju prácu a sliepky tú svoju.
            </p>
            <ul class="story__facts">
              <li><strong>100 %</strong><span>z vlastného chovu</span></li>
              <li><strong>Voľný</strong><span>výbeh pre sliepky</span></li>
              <li><strong>Bez</strong><span>zbytočnej chémie</span></li>
            </ul>
          </div>
          <div class="story__art reveal" aria-hidden="true">
            <div class="scene">
              <svg viewBox="0 0 260 260" class="scene__svg">
                <!-- sun -->
                <circle cx="200" cy="62" r="30" fill="#E9C46A" opacity="0.9" />
                <!-- hill -->
                <path d="M0 200 Q130 150 260 200 V260 H0 Z" fill="#6E7C4F" />
                <path d="M0 224 Q130 188 260 224 V260 H0 Z" fill="#4E5B3A" />
                <!-- hen -->
                <g transform="translate(96 150)">
                  <ellipse cx="40" cy="48" rx="40" ry="30" fill="#fdfaf2" />
                  <circle cx="70" cy="26" r="17" fill="#fdfaf2" />
                  <path d="M70 10 q6 -10 12 -4 q-2 8 -10 9 z" fill="#C0392B" />
                  <path d="M84 24 l11 3 -10 5 z" fill="#E58E26" />
                  <circle cx="80" cy="24" r="2.4" fill="#2A1E12" />
                  <path d="M2 44 q-18 4 -22 18 q16 -2 24 -10 z" fill="#D98A2B" />
                  <path d="M40 78 l-6 14 m18 -14 l4 14" stroke="#E58E26" stroke-width="3" fill="none" stroke-linecap="round" />
                </g>
                <!-- bee -->
                <g class="bee" transform="translate(150 96)">
                  <ellipse cx="0" cy="0" rx="9" ry="6" fill="#E9C46A" />
                  <path d="M-4 -5 v10 M2 -6 v12" stroke="#2A1E12" stroke-width="2" />
                  <ellipse cx="-6" cy="-6" rx="6" ry="3.5" fill="#fff" opacity="0.7" />
                </g>
              </svg>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Objednávka a doručenie ───────────────────────────────── -->
      <section class="section order" id="objednat">
        <div class="container">
          <header class="section__head reveal">
            <p class="eyebrow">Objednávka a doručenie</p>
            <h2 class="section__title">Med a peľ pošleme až k vám</h2>
            <p class="section__sub">
              Med a včelí peľ radi pošleme po Slovensku aj do Česka cez Packetu.
              Čerstvé vajíčka nájdete priamo na farme. Žiadny zložitý e-shop —
              stačí napísať e-mail.
            </p>
          </header>

          <ol class="steps reveal">
            {objednavka.kroky.map((k, i) => (
              <li class="step">
                <span class="step__num">{i + 1}</span>
                <h3 class="step__title">{k.nazov}</h3>
                <p class="step__text">{k.text}</p>
              </li>
